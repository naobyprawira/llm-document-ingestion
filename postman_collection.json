{
  "info": {
    "name": "Document Ingestion API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for ingesting and deleting documents via the Document Ingestion API."
  },
  "item": [
    {
      "name": "Ingest PDF",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": "<path to your PDF file>",
              "description": "PDF document to ingest"
            },
            { "key": "doc_id", "value": "PRB-REG-001", "type": "text" },
            { "key": "scope", "value": "Internal", "type": "text" },
            { "key": "company", "value": "PRB", "type": "text" },
            { "key": "country", "value": "ID", "type": "text" },
            { "key": "language", "value": "id", "type": "text" },
            { "key": "version", "value": "v3.2", "type": "text" },
            { "key": "effective_from", "value": "2025-01-01", "type": "text" },
            { "key": "effective_to", "value": "", "type": "text" },
            { "key": "security_class", "value": "internal", "type": "text" }
          ]
        },
        "url": {
          "raw": "{{base_url}}/ingest/pdf",
          "host": ["{{base_url}}"],
          "path": ["ingest", "pdf"]
        }
      },
      "response": []
    },
    {
      "name": "Delete Document",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/docs/{{doc_id}}",
          "host": ["{{base_url}}"],
          "path": ["docs", "{{doc_id}}"]
        }
      },
      "response": []
    },
    {
      "name": "Delete Document Page",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/docs/{{doc_id}}/pages/{{page}}",
          "host": ["{{base_url}}"],
          "path": ["docs", "{{doc_id}}", "pages", "{{page}}"]
        }
      },
      "response": []
    }
  ],
  "event": [],
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "doc_id", "value": "PRB-REG-001" },
    { "key": "page", "value": "1" }
  ]
}